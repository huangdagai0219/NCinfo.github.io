<!DOCTYPE html>

<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>血糖管理與體重控制指南</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&family=Bebas+Neue&display=swap');

:root {
–bg: #0c0b14;
–panel: #16142a;
–red: #ff4d6d;
–orange: #ff8c42;
–yellow: #ffd166;
–green: #06d6a0;
–teal: #00b4d8;
–blue: #4361ee;
–purple: #9b5de5;
–amber: #f4a261;
–text: #f0eeff;
–muted: #8b80b0;
–border: rgba(255,255,255,0.06);
}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Noto Sans TC’, sans-serif;
padding: 40px 20px 60px;
}

body::before {
content: ‘’;
position: fixed; inset: 0;
background: radial-gradient(ellipse at 20% 20%, rgba(67,97,238,0.06) 0%, transparent 50%),
radial-gradient(ellipse at 80% 80%, rgba(255,77,109,0.04) 0%, transparent 50%);
pointer-events: none; z-index: 0;
}

.wrapper { position: relative; z-index: 1; width: 100%; max-width: 960px; margin: 0 auto; }

/* HEADER */
.main-header { text-align: center; margin-bottom: 52px; }
.main-header .eyebrow { font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: var(–orange); margin-bottom: 12px; }
.main-header h1 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: clamp(36px, 8vw, 72px); line-height: 0.95;
background: linear-gradient(135deg, #ff4d6d 0%, #ff8c42 40%, #ffd166 70%, #06d6a0 100%);
-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
letter-spacing: 2px;
}
.main-header .sub { margin-top: 14px; font-size: 13.5px; color: var(–muted); line-height: 1.85; }

/* TABS */
.scenario-nav { display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap; }
.scenario-nav button {
flex: 1; min-width: 175px; padding: 14px 16px;
border-radius: 14px; border: 1.5px solid var(–border);
background: var(–panel); color: var(–muted);
font-family: ‘Noto Sans TC’, sans-serif; font-size: 13px; font-weight: 500;
cursor: pointer; transition: all 0.25s;
display: flex; align-items: center; gap: 10px; text-align: left;
}
.scenario-nav button .s-icon { font-size: 20px; flex-shrink: 0; }
.scenario-nav button .s-title { font-weight: 700; display: block; font-size: 13.5px; }
.scenario-nav button .s-tag { font-size: 10px; opacity: 0.6; display: block; margin-top: 2px; }
.scenario-nav button[data-s=“0”].active { border-color: var(–red); color: var(–text); background: rgba(255,77,109,0.08); }
.scenario-nav button[data-s=“1”].active { border-color: var(–amber); color: var(–text); background: rgba(244,162,97,0.08); }
.scenario-nav button[data-s=“2”].active { border-color: var(–green); color: var(–text); background: rgba(6,214,160,0.08); }
.scenario-nav button:hover { transform: translateY(-2px); }

/* PANELS */
.scenario-panel { display: none; }
.scenario-panel.active { display: block; animation: fadeUp 0.35s ease; }
@keyframes fadeUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }

/* CHART */
.chart-box {
background: var(–panel); border-radius: 20px; padding: 28px 24px 16px;
border: 1px solid var(–border); box-shadow: 0 32px 64px rgba(0,0,0,0.4); margin-bottom: 24px;
}
.chart-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; flex-wrap: wrap; gap: 10px; }
.chtitle { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(–muted); }
.legend { display: flex; gap: 14px; flex-wrap: wrap; }
.leg-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(–muted); }
.leg-swatch { width: 20px; height: 3px; border-radius: 2px; }

svg.chart { width: 100%; height: auto; display: block; }

/* CARDS */
.cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(195px, 1fr)); gap: 14px; margin-bottom: 24px; }
.card {
background: var(–panel); border-radius: 16px; padding: 18px;
border: 1px solid var(–border); position: relative; overflow: hidden; transition: transform 0.2s;
}
.card:hover { transform: translateY(-3px); }
.card::before { content:’’; position:absolute; top:0; left:0; right:0; height:3px; }
.clabel { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(–muted); margin-bottom: 5px; }
.cname { font-size: 14px; font-weight: 700; margin-bottom: 7px; }
.cdesc { font-size: 12px; color: var(–muted); line-height: 1.7; }
.badge { display: inline-flex; align-items: center; gap: 4px; font-size: 10.5px; font-weight: 700; padding: 3px 10px; border-radius: 20px; margin-top: 10px; }

/* CONCLUSION */
.conclusion { border-radius: 20px; padding: 26px; display: flex; align-items: flex-start; gap: 20px; flex-wrap: wrap; }
.conclusion .big-icon { font-size: 58px; line-height: 1; flex-shrink: 0; }
.conclusion h3 { font-family: ‘Bebas Neue’, sans-serif; font-size: 24px; letter-spacing: 1px; margin-bottom: 10px; }
.conclusion p { font-size: 13px; color: var(–muted); line-height: 1.9; max-width: 580px; }
.conclusion p strong { color: var(–text); }

.tip-row { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
.tip-pill {
display: inline-flex; align-items: center; gap: 7px;
font-size: 11px; padding: 6px 12px; border-radius: 20px;
border: 1px solid rgba(255,255,255,0.1); color: var(–muted);
}
.tip-pill .dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

/* SCENARIO COLORS */
.s0 .card::before { background: var(–red); }
.s0 .conclusion { background: linear-gradient(135deg, rgba(255,77,109,0.07), rgba(155,93,229,0.07)); border: 1px solid rgba(255,77,109,0.2); }
.s0 h3 { color: var(–red); }
.b-red { background: rgba(255,77,109,0.14); color: var(–red); }
.b-orange { background: rgba(255,140,66,0.14); color: var(–orange); }

.s1 .card:nth-child(1)::before, .s1 .card:nth-child(2)::before { background: var(–amber); }
.s1 .card:nth-child(3)::before, .s1 .card:nth-child(4)::before { background: var(–red); }
.s1 .conclusion { background: linear-gradient(135deg, rgba(244,162,97,0.07), rgba(255,77,109,0.07)); border: 1px solid rgba(244,162,97,0.25); }
.s1 h3 { color: var(–amber); }
.b-amber { background: rgba(244,162,97,0.14); color: var(–amber); }

.s2 .card::before { background: var(–green); }
.s2 .conclusion { background: linear-gradient(135deg, rgba(6,214,160,0.07), rgba(67,97,238,0.07)); border: 1px solid rgba(6,214,160,0.2); }
.s2 h3 { color: var(–green); }
.b-green { background: rgba(6,214,160,0.14); color: var(–green); }
.b-teal { background: rgba(0,180,216,0.14); color: var(–teal); }

/* SHAKE HIGHLIGHT */
.shake-highlight { background: rgba(6,214,160,0.06); border: 1px solid rgba(6,214,160,0.18); }
.shake-highlight .cname { color: var(–green); }

@keyframes pulseAnim { 0%,100%{transform:scale(1)} 50%{transform:scale(1.06)} }
.pulse { animation: pulseAnim 2.2s ease-in-out infinite; }
</style>

</head>
